+void ReportEvent::prepare_lfp_cache(NrnThread* nt) {
+    if (lfp_cache_ready_) {
+        return;
+    }
+
+    auto* mapinfo = static_cast<NrnThreadMappingInfo*>(nt->mapping);
+    nrn_assert(mapinfo);
+
+    lfp_output_ptrs_.clear();
+    lfp_segment_ids_.clear();
+    lfp_output_indices_.clear();
+    lfp_factors_.clear();
+
+    for (const auto gid: gids_to_report) {
+        const auto vars_it = vars_to_report.find(gid);
+        if (vars_it == vars_to_report.end()) {
+            continue;
+        }
+
+        const auto& cell_mapping = mapinfo->get_cell_mapping(gid);
+        nrn_assert(cell_mapping != nullptr);
+
+        const int num_electrodes = cell_mapping->num_electrodes();
+        std::vector<double*> ordered_output_ptrs(num_electrodes, nullptr);
+        for (const auto& output: vars_it->second) {
+            nrn_assert(output.id >= 0);
+            nrn_assert(output.id < num_electrodes);
+            ordered_output_ptrs[output.id] = output.var_value;
+        }
+
+        const auto base_output_index = static_cast<int>(lfp_output_ptrs_.size());
+        lfp_output_ptrs_.insert(lfp_output_ptrs_.end(),
+                                ordered_output_ptrs.begin(),
+                                ordered_output_ptrs.end());
+
+        for (const auto& segment_factors: cell_mapping->lfp_factors) {
+            const int segment_id = segment_factors.first;
+            const auto& factors = segment_factors.second;
+            nrn_assert(static_cast<int>(factors.size()) == num_electrodes);
+            for (int electrode_id = 0; electrode_id < num_electrodes; ++electrode_id) {
+                const double factor = factors[electrode_id];
+                if (factor == 0.0) {
+                    continue;
+                }
+                lfp_segment_ids_.push_back(segment_id);
+                lfp_output_indices_.push_back(base_output_index + electrode_id);
+                lfp_factors_.push_back(factor);
+            }
+        }
+    }
+
+    lfp_values_.assign(lfp_output_ptrs_.size(), 0.0);
+
+    if (nt->compute_gpu) {
+        if (!lfp_values_.empty()) {
+            cnrn_target_copyin(lfp_values_.data(), lfp_values_.size());
+        }
+        if (!lfp_segment_ids_.empty()) {
+            cnrn_target_copyin(lfp_segment_ids_.data(), lfp_segment_ids_.size());
+        }
+        if (!lfp_output_indices_.empty()) {
+            cnrn_target_copyin(lfp_output_indices_.data(), lfp_output_indices_.size());
+        }
+        if (!lfp_factors_.empty()) {
+            cnrn_target_copyin(lfp_factors_.data(), lfp_factors_.size());
+        }
+        lfp_gpu_cache_ready_ = true;
+    }
+
+    lfp_cache_ready_ = true;
 }
 
